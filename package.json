{
  "name": "checkflow",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @checkflow/api dev",
    "dev:public": "pnpm --filter @checkflow/public dev",
    "dev:admin": "pnpm --filter @checkflow/admin dev",
    "dev": "pnpm --filter @checkflow/api dev & pnpm --filter @checkflow/public dev -- --host & pnpm --filter @checkflow/admin dev -- --host",
    "build": "pnpm --filter @checkflow/api build && pnpm --filter @checkflow/public build && pnpm --filter @checkflow/admin build",
    "db:migrate": "pnpm --filter @checkflow/api prisma migrate dev",
    "db:seed": "pnpm --filter @checkflow/api prisma db seed",
    "db:generate": "pnpm --filter @checkflow/api prisma generate",
    "test": "pnpm --filter @checkflow/public test && pnpm --filter @checkflow/admin test",
    "test:e2e": "pnpm --filter @checkflow/api exec jest --config test/jest-e2e.json --forceExit --detectOpenHandles",
    "test:all": "pnpm test && pnpm test:e2e"
  }
}
