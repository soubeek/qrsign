datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum GlobalRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  firstName    String      @map("first_name")
  lastName     String      @map("last_name")
  role         GlobalRole  @default(OPERATOR)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt      @map("updated_at")

  refreshTokens RefreshToken[]
  eventAccess   UserEvent[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UserEvent {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  eventId     String      @map("event_id")
  eventRole   GlobalRole? @map("event_role")
  assignedAt  DateTime    @default(now()) @map("assigned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("user_events")
}

model Event {
  id               String        @id @default(uuid())
  slug             String        @unique
  title            String
  subtitle         String?
  logoEmoji        String        @default("🏛️")  @map("logo_emoji")
  entitySingular   String        @default("participant") @map("entity_singular")
  entityPlural     String        @default("participants") @map("entity_plural")
  displayNameTpl   String        @default("{prenom} {nom}") @map("display_name_tpl")
  searchFields     String[]      @default(["nom","prenom"]) @map("search_fields")
  isActive         Boolean       @default(true)  @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt      @map("updated_at")

  fields           FieldDef[]
  documents        DocumentDef[]
  emailConfig      EmailConfig?
  participants     Participant[]
  userAccess       UserEvent[]

  @@map("events")
}

enum FieldType {
  TEXT
  EMAIL
  TEL
  DATE
  SELECT
  TEXTAREA
  NUMBER
}

model FieldDef {
  id            String    @id @default(uuid())
  eventId       String    @map("event_id")
  key           String
  label         String
  type          FieldType
  options       String[]  @default([])
  editable      Boolean   @default(true)
  required      Boolean   @default(false)
  displayInList Boolean   @default(false)       @map("display_in_list")
  displayOrder  Int       @default(0)           @map("display_order")
  isQrField     Boolean   @default(false)       @map("is_qr_field")
  isEmailField  Boolean   @default(false)       @map("is_email_field")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, key])
  @@map("field_defs")
}

// Un Event peut avoir N documents a signer
model DocumentDef {
  id                  String @id @default(uuid())
  eventId             String @map("event_id")
  title               String @default("Consentement")
  signingLabel        String @default("Signer le document") @map("signing_label")
  declarationTemplate String @map("declaration_template")
  noticeSections      Json   @default("[]") @map("notice_sections")
  pdfFooterText       String @default("") @map("pdf_footer_text")
  signatureWidthMm    Int    @default(75)  @map("signature_width_mm")
  signatureHeightMm   Int    @default(28)  @map("signature_height_mm")
  logoPath            String? @map("logo_path")
  logoPosition        String  @default("center") @map("logo_position")
  titlePosition       String  @default("center") @map("title_position")
  backgroundPath      String? @map("background_path")
  displayOrder        Int     @default(0) @map("display_order")
  required            Boolean @default(true)

  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  signatures ParticipantSignature[]

  @@map("document_defs")
}

model EmailConfig {
  id              String  @id @default(uuid())
  eventId         String  @unique @map("event_id")

  smtpHost        String  @map("smtp_host")
  smtpPort        Int     @default(587) @map("smtp_port")
  smtpSecure      Boolean @default(false) @map("smtp_secure")
  smtpUser        String  @map("smtp_user")
  smtpPass        String  @map("smtp_pass")
  fromAddress     String  @map("from_address")
  fromName        String  @map("from_name")

  autoSendOnSign  Boolean @default(false) @map("auto_send_on_sign")
  allowManualSend Boolean @default(true)  @map("allow_manual_send")

  subject         String  @default("Votre document signe")
  bodyTemplate    String  @map("body_template")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("email_configs")
}

enum Status {
  ABSENT
  PRESENT
  SIGNED
}

model Participant {
  id            String    @id @default(uuid())
  eventId       String    @map("event_id")
  qrCode        String    @map("qr_code")
  status        Status    @default(ABSENT)
  data          Json
  emailSentAt   DateTime? @map("email_sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  signatures ParticipantSignature[]

  @@unique([eventId, qrCode])
  @@map("participants")
}

// Signature d'un participant pour un document specifique
model ParticipantSignature {
  id              String    @id @default(uuid())
  participantId   String    @map("participant_id")
  documentDefId   String    @map("document_def_id")
  signedAt        DateTime  @default(now()) @map("signed_at")
  pdfPath         String?   @map("pdf_path")
  createdAt       DateTime  @default(now()) @map("created_at")

  participant  Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  documentDef  DocumentDef @relation(fields: [documentDefId], references: [id], onDelete: Cascade)

  @@unique([participantId, documentDefId])
  @@map("participant_signatures")
}
